<Page
    x:Class="neo_bpsys_wpf.ExamplePlugin.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:neo_bpsys_wpf.ExamplePlugin"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="MainPage"
    d:DataContext="{d:DesignInstance Type=local:MainPageViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    d:Foreground="White"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/neo-bpsys-wpf.Core;component/Styles/Card.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>
    <WrapPanel Margin="10" Orientation="Horizontal">
        <Border
            Padding="10"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock VerticalAlignment="Center">
                    <Run Text="Current count: " /><Run Text="{Binding Counter}">
                    </Run>
                </TextBlock>
                <ui:Button
                    Width="80"
                    Height="30"
                    Margin="10"
                    d:Content="0"
                    Command="{Binding Plus1Command}"
                    Content="Click Me"
                    Icon="{ui:SymbolIcon Symbol=Add24}" />
            </StackPanel>
        </Border>
    </WrapPanel>
</Page>
