<ui:FluentWindow
    x:Class="neo_bpsys_wpf.Views.Windows.FrontedBindingBrowserWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:neo_bpsys_wpf.Controls"
    xmlns:designer="clr-namespace:neo_bpsys_wpf.Core.Models.FrontedLayout.Designer;assembly=neo-bpsys-wpf.Core"
    xmlns:lex="http://wpflocalizeextension.codeplex.com"
    xmlns:limits="clr-namespace:neo_bpsys_wpf.Core.Services.FrontedLayout;assembly=neo-bpsys-wpf.Core"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="{lex:Loc Designer.Editor.BindingBrowser}"
    Width="640"
    Height="620"
    MinWidth="520"
    MinHeight="420"
    lex:LocalizeDictionary.DesignCulture="zh"
    lex:ResxLocalizationProvider.DefaultAssembly="neo-bpsys-wpf"
    lex:ResxLocalizationProvider.DefaultDictionary="Locales.Lang"
    Background="{DynamicResource ApplicationBackgroundBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    WindowStartupLocation="CenterOwner">
    <ui:FluentWindow.Resources>
        <HierarchicalDataTemplate DataType="{x:Type designer:FrontedBindingTreeNode}" ItemsSource="{Binding Children}">
            <StackPanel Margin="0,2">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding DisplayName}" />
                    <TextBlock
                        Margin="8,0,0,0"
                        Opacity="0.6"
                        Text="{Binding TypeName}" />
                </StackPanel>
                <TextBlock
                    FontSize="11"
                    Opacity="0.65"
                    Text="{Binding FullPath}" />
            </StackPanel>
        </HierarchicalDataTemplate>
    </ui:FluentWindow.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="35"
            CornerRadius="8"
            GlassFrameThickness="0"
            ResizeBorderThickness="5"
            UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <controls:CustomTitleBar
            Grid.Row="0"
            Icon="/Assets/icon.png"
            IsMaximizeVisible="True"
            IsMinimizeVisible="True"
            IsThemeChangeVisible="False"
            IsTopMostVisible="False" />
        <TextBlock
            Grid.Row="1"
            Margin="12,12,12,0"
            FontWeight="SemiBold"
            Text="{Binding ExpectedBindingTypeDisplay}" />
        <ui:TextBox
            Grid.Row="2"
            Margin="12"
            MaxLength="{x:Static limits:FrontedLayoutLimits.MaxSearchTextLength}"
            PlaceholderText="{lex:Loc Designer.Editor.Search}"
            Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        <Grid Grid.Row="3" Margin="12,0,12,12">
            <TreeView
                SelectedItemChanged="BindingTree_OnSelectedItemChanged"
                ItemsSource="{Binding TreeNodes}">
                <TreeView.Style>
                    <Style TargetType="TreeView">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasSearchText}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TreeView.Style>
            </TreeView>
            <ListBox
                ItemsSource="{Binding SearchResults}"
                SelectionChanged="BindingSearch_OnSelectionChanged">
                <ListBox.Style>
                    <Style TargetType="ListBox">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasSearchText}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.Style>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type designer:FrontedBindingTreeNode}">
                        <StackPanel Margin="0,4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                <TextBlock
                                    Margin="8,0,0,0"
                                    Opacity="0.6"
                                    Text="{Binding TypeName}" />
                            </StackPanel>
                            <TextBlock Opacity="0.7" Text="{Binding FullPath}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Opacity="0.65"
                Text="{lex:Loc Designer.Editor.NoResults}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasNoResults}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
        <StackPanel Grid.Row="4" Margin="12,0,12,12">
            <TextBlock FontWeight="SemiBold" Text="{lex:Loc Designer.Editor.RawPath}" />
            <ui:TextBox
                Margin="0,6,0,0"
                IsReadOnly="True"
                MaxLength="{x:Static limits:FrontedLayoutLimits.MaxBindingPathLength}"
                Text="{Binding SelectedPath}" />
        </StackPanel>
        <StackPanel
            Grid.Row="5"
            Margin="12,0,12,12"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <ui:Button
                MinWidth="96"
                Click="UseSelected_OnClick"
                Content="{lex:Loc Designer.Editor.Select}" />
            <ui:Button
                MinWidth="96"
                Margin="8,0,0,0"
                Click="Cancel_OnClick"
                Content="{lex:Loc Designer.Editor.Cancel}" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
