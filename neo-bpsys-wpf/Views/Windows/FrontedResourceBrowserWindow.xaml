<ui:FluentWindow
    x:Class="neo_bpsys_wpf.Views.Windows.FrontedResourceBrowserWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:neo_bpsys_wpf.Controls"
    xmlns:designer="clr-namespace:neo_bpsys_wpf.Core.Models.FrontedLayout.Designer;assembly=neo-bpsys-wpf.Core"
    xmlns:lex="http://wpflocalizeextension.codeplex.com"
    xmlns:limits="clr-namespace:neo_bpsys_wpf.Core.Services.FrontedLayout;assembly=neo-bpsys-wpf.Core"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="{lex:Loc ResourceBrowser}"
    Width="760"
    Height="620"
    MinWidth="560"
    MinHeight="420"
    lex:LocalizeDictionary.DesignCulture="zh"
    lex:ResxLocalizationProvider.DefaultAssembly="neo-bpsys-wpf"
    lex:ResxLocalizationProvider.DefaultDictionary="Locales.Lang"
    Background="{DynamicResource ApplicationBackgroundBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    WindowStartupLocation="CenterOwner">
    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="35"
            CornerRadius="8"
            GlassFrameThickness="0"
            ResizeBorderThickness="5"
            UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <controls:CustomTitleBar
            Grid.Row="0"
            Icon="/Assets/icon.png"
            IsMaximizeVisible="True"
            IsMinimizeVisible="True"
            IsThemeChangeVisible="False"
            IsTopMostVisible="False" />
        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBox
                Grid.Column="0"
                MaxLength="{x:Static limits:FrontedLayoutLimits.MaxSearchTextLength}"
                PlaceholderText="{lex:Loc SearchResources}"
                Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <ui:Button
                Grid.Column="1"
                MinWidth="120"
                Margin="8,0,0,0"
                Click="BrowseFile_OnClick"
                Content="{lex:Loc BrowseFile}" />
        </Grid>
        <Grid Grid.Row="2" Margin="12,0,12,12">
            <ListBox
                ItemsSource="{Binding Resources}"
                SelectionChanged="ResourceList_OnSelectionChanged"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type designer:FrontedResourceBrowserItem}">
                        <Border Width="170" Height="132" Margin="4" Padding="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="72" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Border
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1">
                                    <Image
                                        Margin="2"
                                        Source="{Binding Thumbnail}"
                                        Stretch="Uniform" />
                                </Border>
                                <TextBlock
                                    Grid.Row="1"
                                    Margin="0,6,0,0"
                                    FontWeight="SemiBold"
                                    Text="{Binding DisplayName}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Grid.Row="2"
                                    Opacity="0.7"
                                    Text="{Binding SelectedPath}"
                                    TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Opacity="0.65"
                Text="{lex:Loc NoResourceResults}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasNoResults}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
        <StackPanel Grid.Row="3" Margin="12,0,12,12">
            <TextBlock FontWeight="SemiBold" Text="{lex:Loc SelectedPath}" />
            <ui:TextBox
                Margin="0,6,0,0"
                IsReadOnly="True"
                MaxLength="{x:Static limits:FrontedLayoutLimits.MaxResourcePathLength}"
                Text="{Binding SelectedPath}" />
        </StackPanel>
        <TextBlock
            Grid.Row="4"
            Margin="12,0,12,8"
            Foreground="{DynamicResource SystemFillColorCriticalBrush}"
            Text="{Binding ValidationMessage}"
            TextWrapping="Wrap" />
        <StackPanel
            Grid.Row="5"
            Margin="12,0,12,12"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <ui:Button
                MinWidth="96"
                Click="UseSelected_OnClick"
                Content="{lex:Loc UseSelected}" />
            <ui:Button
                MinWidth="96"
                Margin="8,0,0,0"
                Click="Cancel_OnClick"
                Content="{lex:Loc Cancel}" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
