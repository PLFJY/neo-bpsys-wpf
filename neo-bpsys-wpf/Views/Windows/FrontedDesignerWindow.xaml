<ui:FluentWindow
    x:Class="neo_bpsys_wpf.Views.Windows.FrontedDesignerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:neo_bpsys_wpf.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lex="http://wpflocalizeextension.codeplex.com"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:neo_bpsys_wpf.ViewModels.Windows"
    Title="{lex:Loc FrontedDesigner}"
    Width="1500"
    Height="900"
    MinWidth="1100"
    MinHeight="700"
    d:DataContext="{d:DesignInstance Type=vm:FrontedDesignerWindowViewModel,
                                     IsDesignTimeCreatable=True}"
    lex:LocalizeDictionary.DesignCulture="zh"
    lex:ResxLocalizationProvider.DefaultAssembly="neo-bpsys-wpf"
    lex:ResxLocalizationProvider.DefaultDictionary="Locales.Lang"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Background="{DynamicResource ApplicationBackgroundBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="35"
            CornerRadius="8"
            GlassFrameThickness="0"
            ResizeBorderThickness="5"
            UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <controls:CustomTitleBar
            Grid.Row="0"
            Icon="/Assets/icon.png"
            IsMaximizeVisible="True"
            IsMinimizeVisible="True"
            IsThemeChangeVisible="False"
            IsTopMostVisible="False" />

        <Border
            Grid.Row="1"
            Padding="12"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ComboBox
                    Grid.Column="0"
                    Width="190"
                    DisplayMemberPath="DisplayName"
                    ItemsSource="{Binding WindowOptions}"
                    SelectedItem="{Binding SelectedWindow}"
                    SelectionChanged="Selector_OnSelectionChanged" />
                <ComboBox
                    Grid.Column="1"
                    Width="190"
                    Margin="8,0,0,0"
                    DisplayMemberPath="CanvasDisplayName"
                    ItemsSource="{Binding CanvasOptions}"
                    SelectedItem="{Binding SelectedCanvas}"
                    SelectionChanged="Selector_OnSelectionChanged" />
                <ui:Button
                    Grid.Column="2"
                    Margin="8,0,0,0"
                    Command="{Binding ReloadLayoutCommand}"
                    Content="{lex:Loc ReloadLayout}"
                    Icon="{ui:SymbolIcon Symbol=ArrowClockwise24}" />
                <ui:Button
                    Grid.Column="3"
                    Margin="8,0,0,0"
                    Command="{Binding ValidateLayoutCommand}"
                    Content="{lex:Loc ValidateLayout}"
                    Icon="{ui:SymbolIcon Symbol=CheckmarkCircle24}" />
                <TextBlock
                    Grid.Column="4"
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    Text="{Binding ZoomDisplay}" />
                <StackPanel
                    Grid.Column="5"
                    Margin="16,0,0,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Text="{lex:Loc Zoom}" />
                    <ui:Button
                        Margin="8,0,0,0"
                        Command="{Binding ZoomOutCommand}"
                        Icon="{ui:SymbolIcon Symbol=Subtract24}"
                        ToolTip="{lex:Loc ZoomOut}" />
                    <ComboBox
                        Width="90"
                        Margin="8,0,0,0"
                        DisplayMemberPath="DisplayName"
                        ItemsSource="{Binding ZoomPresets}"
                        SelectedItem="{Binding SelectedZoomPreset}" />
                    <ui:Button
                        Margin="8,0,0,0"
                        Command="{Binding ZoomInCommand}"
                        Icon="{ui:SymbolIcon Symbol=Add24}"
                        ToolTip="{lex:Loc ZoomIn}" />
                    <ui:Button
                        Margin="8,0,12,0"
                        Command="{Binding FitToWindowCommand}"
                        Content="{lex:Loc Fit}"
                        Icon="{ui:SymbolIcon Symbol=FullScreenMaximize24}"
                        ToolTip="{lex:Loc FitToWindow}" />
                    <TextBlock Text="{lex:Loc LayoutSource}" />
                    <TextBlock Margin="8,0,0,0" Text="{Binding LayoutSourceDisplay}" />
                    <TextBlock Margin="8,0,0,0" Text="{Binding LayoutSourcePath}" />
                </StackPanel>
                <TextBlock
                    Grid.Column="6"
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="18"
                    Text="{Binding DirtyIndicatorText}" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Margin="12"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4">
                <ScrollViewer
                    x:Name="PreviewViewport"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
                    <Grid
                        MinWidth="640"
                        MinHeight="420"
                        Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}">
                        <Viewbox
                            MaxWidth="{Binding ActualWidth, ElementName=PreviewViewport}"
                            MaxHeight="{Binding ActualHeight, ElementName=PreviewViewport}"
                            Stretch="{Binding PreviewStretch}">
                            <Border
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1">
                                <Border.LayoutTransform>
                                    <ScaleTransform ScaleX="{Binding ZoomScale}" ScaleY="{Binding ZoomScale}" />
                                </Border.LayoutTransform>
                                <Canvas
                                    x:Name="PreviewCanvas"
                                    Width="640"
                                    Height="360"
                                    ClipToBounds="True"
                                    SnapsToDevicePixels="True" />
                            </Border>
                        </Viewbox>
                    </Grid>
                </ScrollViewer>
            </Border>

            <Border
                Grid.Column="1"
                Margin="0,12,12,12"
                Padding="12"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="{lex:Loc Validation}" />
                    <UniformGrid
                        Grid.Row="1"
                        Margin="0,12,0,12"
                        Columns="3">
                        <StackPanel>
                            <TextBlock Text="{lex:Loc Errors}" />
                            <TextBlock FontSize="20" Text="{Binding ErrorCount}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{lex:Loc Warnings}" />
                            <TextBlock FontSize="20" Text="{Binding WarningCount}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{lex:Loc Infos}" />
                            <TextBlock FontSize="20" Text="{Binding InfoCount}" />
                        </StackPanel>
                    </UniformGrid>
                    <DataGrid
                        Grid.Row="2"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        HeadersVisibility="Column"
                        IsReadOnly="True"
                        ItemsSource="{Binding ValidationMessages}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Severity}" Header="Severity" Width="70" />
                            <DataGridTextColumn Binding="{Binding Code}" Header="Code" Width="110" />
                            <DataGridTextColumn Binding="{Binding ControlName}" Header="Control" Width="90" />
                            <DataGridTextColumn Binding="{Binding PropertyName}" Header="Property" Width="90" />
                            <DataGridTextColumn Binding="{Binding Message}" Header="Message" Width="240" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Border
            Grid.Row="3"
            Padding="12,8"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Left" Text="{Binding StatusMessage}" />
                <TextBlock
                    HorizontalAlignment="Right"
                    Text="{Binding CurrentWindowCanvasDisplay}" />
            </DockPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
