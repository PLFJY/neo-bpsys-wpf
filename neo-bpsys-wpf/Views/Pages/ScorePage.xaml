<Page
    x:Class="neo_bpsys_wpf.Views.Pages.ScorePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lex="http://wpflocalizeextension.codeplex.com"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:neo_bpsys_wpf.ViewModels.Pages"
    Title="ScorePage"
    d:DataContext="{d:DesignInstance Type=vm:ScorePageViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1500"
    d:DesignWidth="900"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d">
    <WrapPanel Orientation="Horizontal">
        <Border Margin="0,0,10,10" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock
                    Grid.Row="0"
                    Style="{StaticResource Title}"
                    Text="{lex:Loc ScoreControl}" />
                <Grid Grid.Row="1" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="350" />
                    </Grid.ColumnDefinitions>
                    <Grid.Resources>
                        <Style BasedOn="{StaticResource {x:Type Button}}" TargetType="Button">
                            <Setter Property="Width" Value="80" />
                            <Setter Property="Height" Value="40" />
                            <Setter Property="Margin" Value="10" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </Grid.Resources>
                    <StackPanel Grid.Column="0">
                        <Button
                            Width="100"
                            Command="{Binding Escape4Command}"
                            Content="{lex:Loc FourEscape}" />
                        <Button
                            Width="100"
                            Command="{Binding Escape3Command}"
                            Content="{lex:Loc ThreeEscape}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,30,0,0">
                        <Button
                            Width="140"
                            Command="{Binding TieCommand}"
                            Content="{lex:Loc Tie}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <Button
                            Width="100"
                            Command="{Binding Out4Command}"
                            Content="{lex:Loc FourEliminate}" />
                        <Button
                            Width="102"
                            Command="{Binding Out3Command}"
                            Content="{lex:Loc ThreeEliminate}" />
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <Button
                            Width="150"
                            Command="{Binding ResetCommand}"
                            Content="{lex:Loc ResetAllScores}" />
                        <Button
                            Width="150"
                            Command="{Binding ClearCurrentHalfScoreCommand}"
                            Content="{lex:Loc ClearCurrentHalfScore}" />
                        <Button
                            Width="150"
                            Command="{Binding ManualControlCommand}"
                            Content="{lex:Loc ControlManually}" />
                    </StackPanel>
                </Grid>
                <StackPanel
                    Grid.Row="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock Margin="0,0,20,10" d:Text="主队名称  W:0 D:0  小比分: 0">
                        <TextBlock.Text>
                            <MultiBinding Converter="{lex:StringFormatConverter}">
                                <lex:BLoc Key="ScorePreview" />
                                <Binding Path="HomeTeam.Name" />
                                <Binding Path="HomeTeam.Score.Win" />
                                <Binding Path="HomeTeam.Score.Tie" />
                                <Binding Path="HomeTeam.Score.GameScores" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock d:Text="客队名称  W:0 D:0  小比分: 0">
                        <TextBlock.Text>
                            <MultiBinding Converter="{lex:StringFormatConverter}">
                                <lex:BLoc Key="ScorePreview" />
                                <Binding Path="AwayTeam.Name" />
                                <Binding Path="AwayTeam.Score.Win" />
                                <Binding Path="AwayTeam.Score.Tie" />
                                <Binding Path="AwayTeam.Score.GameScores" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
        <Border Style="{StaticResource Card}" Visibility="{Binding IsDebugContentVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border.Resources>
                <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            </Border.Resources>
            <StackPanel>
                <DataGrid ItemsSource="{Binding GameGlobalInfoRecord}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Binding="{Binding Key}" Header="Key" />
                        <DataGridTextColumn Binding="{Binding Value.IsGameFinished}" Header="IsGameFinished" />
                        <DataGridTextColumn Binding="{Binding Value.HomeTeamCamp}" Header="HomeTeamCamp" />
                        <DataGridTextColumn Binding="{Binding Value.GameResult}" Header="GameResult" />
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </WrapPanel>
</Page>
