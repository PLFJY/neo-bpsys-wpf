<Page
    x:Class="neo_bpsys_wpf.Views.Pages.ScorePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lex="http://wpflocalizeextension.codeplex.com"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:neo_bpsys_wpf.ViewModels.Pages"
    Title="ScorePage"
    d:DataContext="{d:DesignInstance Type=vm:ScorePageViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1500"
    d:DesignWidth="900"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d">
    <WrapPanel Orientation="Horizontal">
        <Border Margin="0,0,10,10" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock
                    Grid.Row="0"
                    Style="{StaticResource Title}"
                    Text="{lex:Loc ScoreControl}" />
                <Grid Grid.Row="1" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="350" />
                    </Grid.ColumnDefinitions>
                    <Grid.Resources>
                        <Style BasedOn="{StaticResource {x:Type Button}}" TargetType="Button">
                            <Setter Property="Width" Value="80" />
                            <Setter Property="Height" Value="40" />
                            <Setter Property="Margin" Value="10" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </Grid.Resources>
                    <StackPanel Grid.Column="0">
                        <Button
                            Width="100"
                            Command="{Binding Escape4Command}"
                            Content="{lex:Loc FourEscape}" />
                        <Button
                            Width="100"
                            Command="{Binding Escape3Command}"
                            Content="{lex:Loc ThreeEscape}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,30,0,0">
                        <Button
                            Width="140"
                            Command="{Binding TieCommand}"
                            Content="{lex:Loc Tie}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <Button
                            Width="100"
                            Command="{Binding Out4Command}"
                            Content="{lex:Loc FourEliminate}" />
                        <Button
                            Width="102"
                            Command="{Binding Out3Command}"
                            Content="{lex:Loc ThreeEliminate}" />
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <Button
                            Width="150"
                            Command="{Binding ResetCommand}"
                            Content="{lex:Loc ResetAllScores}" />
                        <Button
                            Width="150"
                            Command="{Binding ClearCurrentHalfScoreCommand}"
                            Content="{lex:Loc ClearCurrentHalfScore}" />
                    </StackPanel>
                </Grid>
                <StackPanel
                    Grid.Row="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock Margin="0,0,20,10" d:Text="主队名称  W:0 D:0  小比分: 0">
                        <TextBlock.Text>
                            <MultiBinding Converter="{lex:StringFormatConverter}">
                                <lex:BLoc Key="ScorePreview" />
                                <Binding Path="HomeTeam.Name" />
                                <Binding Path="CurrentGame.MatchScore.HomeMajorWin" />
                                <Binding Path="CurrentGame.MatchScore.HomeMajorTie" />
                                <Binding Path="CurrentGame.MatchScore.HomeTotalMinorScore" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock d:Text="客队名称  W:0 D:0  小比分: 0">
                        <TextBlock.Text>
                            <MultiBinding Converter="{lex:StringFormatConverter}">
                                <lex:BLoc Key="ScorePreview" />
                                <Binding Path="AwayTeam.Name" />
                                <Binding Path="CurrentGame.MatchScore.AwayMajorWin" />
                                <Binding Path="CurrentGame.MatchScore.AwayMajorTie" />
                                <Binding Path="CurrentGame.MatchScore.AwayTotalMinorScore" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
        <Border
            Width="860"
            Margin="0,0,10,10"
            Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel
                    Grid.Row="0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{StaticResource Title}"
                        Text="{lex:Loc ScorePreviewTable}" />
                    <Button
                        Margin="16,0,0,0"
                        Padding="12,4"
                        Click="RestoreScorePreviewDefaultSort_Click"
                        Content="{lex:Loc RestoreDefaultSort}" />
                </StackPanel>
                <ui:DataGrid
                    x:Name="ScorePreviewDataGrid"
                    Grid.Row="1"
                    MinHeight="320"
                    Margin="0,10,0,0"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    HeadersVisibility="Column"
                    IsReadOnly="True"
                    ItemsSource="{Binding ScorePreviewRows}"
                    SelectionMode="Single">
                    <ui:DataGrid.RowStyle>
                        <Style TargetType="{x:Type DataGridRow}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCurrentProgress}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:DataGrid.RowStyle>
                    <ui:DataGrid.Columns>
                        <DataGridTextColumn
                            Width="90"
                            Binding="{Binding GameLabel}"
                            Header="{lex:Loc ScorePreviewGame}" />
                        <DataGridTextColumn
                            Width="80"
                            Binding="{Binding HalfLabel}"
                            Header="{lex:Loc ScorePreviewHalf}" />
                        <DataGridTextColumn
                            Width="80"
                            Binding="{Binding RowStatusText}"
                            Header="{lex:Loc ScorePreviewStatus}" />
                        <DataGridTextColumn
                            Width="80"
                            Binding="{Binding ResultText}"
                            Header="{lex:Loc ScorePreviewResult}" />
                        <DataGridTextColumn
                            Width="110"
                            Binding="{Binding HomeCampText}"
                            Header="{lex:Loc ScorePreviewHomeCamp}" />
                        <DataGridTextColumn
                            Width="110"
                            Binding="{Binding AwayCampText}"
                            Header="{lex:Loc ScorePreviewAwayCamp}" />
                        <DataGridTextColumn
                            Width="120"
                            Binding="{Binding HomeMinorScoreText}"
                            Header="{lex:Loc ScorePreviewHomeMinorScore}" />
                        <DataGridTextColumn
                            Width="120"
                            Binding="{Binding AwayMinorScoreText}"
                            Header="{lex:Loc ScorePreviewAwayMinorScore}" />
                    </ui:DataGrid.Columns>
                </ui:DataGrid>
            </Grid>
        </Border>
    </WrapPanel>
</Page>
