<Page
    x:Class="neo_bpsys_wpf.Views.Pages.FrontManagePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cv="clr-namespace:neo_bpsys_wpf.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:enums="clr-namespace:neo_bpsys_wpf.Core.Enums;assembly=neo-bpsys-wpf.Core"
    xmlns:lex="http://wpflocalizeextension.codeplex.com"
    xmlns:local="clr-namespace:neo_bpsys_wpf.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:neo_bpsys_wpf.ViewModels.Pages"
    Title="FrontManagePage"
    d:DataContext="{d:DesignInstance Type=vm:FrontManagePageViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1500"
    d:DesignWidth="685"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d">
    <Page.Resources>
        <ResourceDictionary>
            <cv:StringToDoubleConverter x:Key="StringToDoubleConverter" />
            <cv:MultiCommandParameterConverter x:Key="MultiCommandParameterConverter" />
        </ResourceDictionary>
    </Page.Resources>
    <TabControl Margin="10,0,0,0">
        <TabItem Header="{lex:Loc FrontendWindows}">
            <WrapPanel Orientation="Horizontal">
                <Border Margin="0,0,10,10" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            Style="{StaticResource Title}"
                            Text="{lex:Loc AllFrontendWindows}" />
                        <StackPanel
                            Grid.Row="1"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Center"
                            Orientation="Horizontal">
                            <ui:Button
                                Height="50"
                                Command="{Binding OpenFrontedDesignerCommand}"
                                Content="{lex:Loc OpenFrontedDesigner}"
                                Icon="{ui:SymbolIcon Symbol=Edit24}" />
                            <ui:Button
                                Height="50"
                                Margin="10,0,0,0"
                                Command="{Binding ShowAllWindowsCommand}"
                                Content="{lex:Loc OpenAll}" />
                            <ui:Button
                                Height="50"
                                Margin="10,0,0,0"
                                Command="{Binding HideAllWindowsCommand}"
                                Content="{lex:Loc CloseAll}" />
                        </StackPanel>
                        <TextBlock
                            Grid.Row="2"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Left"
                            Text="{lex:Loc DesignerUnlockNote}"
                            TextWrapping="WrapWithOverflow" />
                    </Grid>
                </Border>
                <Border Margin="0,0,10,10" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            Style="{StaticResource Title}"
                            Text="{lex:Loc BPWindow}" />
                        <StackPanel
                            Grid.Row="1"
                            Margin="0,10,0,0"
                            Orientation="Horizontal">
                            <ui:Button
                                Command="{Binding ShowWindowCommand}"
                                CommandParameter="{x:Static enums:FrontedWindowType.BpWindow}"
                                Content="{lex:Loc Open}" />
                            <ui:Button
                                Margin="10,0,0,0"
                                Command="{Binding HideWindowCommand}"
                                CommandParameter="{x:Static enums:FrontedWindowType.BpWindow}"
                                Content="{lex:Loc Close}" />
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Margin="0,0,10,10" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            Style="{StaticResource Title}"
                            Text="{lex:Loc CutSceneWindow}" />
                        <StackPanel
                            Grid.Row="1"
                            Margin="0,10,0,0"
                            Orientation="Horizontal">
                            <ui:Button
                                Command="{Binding ShowWindowCommand}"
                                CommandParameter="{x:Static enums:FrontedWindowType.CutSceneWindow}"
                                Content="{lex:Loc Open}" />
                            <ui:Button
                                Margin="10,0,0,0"
                                Command="{Binding HideWindowCommand}"
                                CommandParameter="{x:Static enums:FrontedWindowType.CutSceneWindow}"
                                Content="{lex:Loc Close}" />
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Margin="0,0,10,10" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            Style="{StaticResource Title}"
                            Text="{lex:Loc ScoreComponent}" />
                        <StackPanel
                            Grid.Row="1"
                            Margin="0,10,0,0"
                            Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Text="{lex:Loc SurvivorScoreInGame}" />
                            <ui:Button
                                Margin="10,0,0,0"
                                Command="{Binding ShowWindowCommand}"
                                CommandParameter="{x:Static enums:FrontedWindowType.ScoreSurWindow}"
                                Content="{lex:Loc Open}" />
                            <ui:Button
                                Margin="10,0,0,0"
                                Command="{Binding HideWindowCommand}"
                                CommandParameter="{x:Static enums:FrontedWindowType.ScoreSurWindow}"
                                Content="{lex:Loc Close}" />
                        </StackPanel>
                        <StackPanel
                            Grid.Row="2"
                            Margin="0,10,0,0"
                            Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Text="{lex:Loc HunterScoreInGame}" />
                            <ui:Button
                                Margin="10,0,0,0"
                                Command="{Binding ShowWindowCommand}"
                                CommandParameter="{x:Static enums:FrontedWindowType.ScoreHunWindow}"
                                Content="{lex:Loc Open}" />
                            <ui:Button
                                Margin="10,0,0,0"
                                Command="{Binding HideWindowCommand}"
                                CommandParameter="{x:Static enums:FrontedWindowType.ScoreHunWindow}"
                                Content="{lex:Loc Close}" />
                        </StackPanel>
                        <StackPanel
                            Grid.Row="3"
                            Margin="0,10,0,0"
                            Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Text="{lex:Loc ScoreStatistics}" />
                            <ui:Button
                                Margin="10,0,0,0"
                                Command="{Binding ShowWindowCommand}"
                                CommandParameter="{x:Static enums:FrontedWindowType.ScoreGlobalWindow}"
                                Content="{lex:Loc Open}" />
                            <ui:Button
                                Margin="10,0,0,0"
                                Command="{Binding HideWindowCommand}"
                                CommandParameter="{x:Static enums:FrontedWindowType.ScoreGlobalWindow}"
                                Content="{lex:Loc Close}" />
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Margin="0,0,10,10" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            Style="{StaticResource Title}"
                            Text="{lex:Loc GameStatisticsWindow}" />
                        <StackPanel
                            Grid.Row="1"
                            Margin="0,10,0,0"
                            Orientation="Horizontal">
                            <ui:Button
                                Command="{Binding ShowWindowCommand}"
                                CommandParameter="{x:Static enums:FrontedWindowType.GameDataWindow}"
                                Content="{lex:Loc Open}" />
                            <ui:Button
                                Margin="10,0,0,0"
                                Command="{Binding HideWindowCommand}"
                                CommandParameter="{x:Static enums:FrontedWindowType.GameDataWindow}"
                                Content="{lex:Loc Close}" />
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Margin="0,0,10,10" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            Style="{StaticResource Title}"
                            Text="{lex:Loc Widgets}" />
                        <StackPanel
                            Grid.Row="1"
                            Margin="0,10,0,0"
                            Orientation="Horizontal">
                            <ui:Button
                                Command="{Binding ShowWindowCommand}"
                                CommandParameter="{x:Static enums:FrontedWindowType.WidgetsWindow}"
                                Content="{lex:Loc Open}" />
                            <ui:Button
                                Margin="10,0,0,0"
                                Command="{Binding HideWindowCommand}"
                                CommandParameter="{x:Static enums:FrontedWindowType.WidgetsWindow}"
                                Content="{lex:Loc Close}" />
                        </StackPanel>
                    </Grid>
                </Border>
                <ItemsControl ItemsSource="{Binding ExternalFrontedWindows}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,10,10" Style="{StaticResource Card}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock
                                        Grid.Row="0"
                                        Style="{StaticResource Title}"
                                        Text="{Binding Name}" />
                                    <StackPanel
                                        Grid.Row="1"
                                        Margin="0,10,0,0"
                                        Orientation="Horizontal">
                                        <ui:Button
                                            Command="{Binding RelativeSource={RelativeSource AncestorType=ItemsControl}, Path=DataContext.ShowWindowCommand}"
                                            CommandParameter="{Binding Id}"
                                            Content="{lex:Loc Open}" />
                                        <ui:Button
                                            Margin="10,0,0,0"
                                            Command="{Binding RelativeSource={RelativeSource AncestorType=ItemsControl}, Path=DataContext.HideWindowCommand}"
                                            CommandParameter="{Binding Id}"
                                            Content="{lex:Loc Close}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </WrapPanel>
        </TabItem>
        <TabItem Header="{lex:Loc LayoutPackages}">
            <Grid Margin="0,0,10,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" MinWidth="340" />
                    <ColumnDefinition Width="*" MinWidth="360" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.ColumnSpan="3" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Style="{StaticResource Title}" Text="{lex:Loc LayoutPackageManager}" />
                        <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="{lex:Loc ActivePackage}" />
                            <Run Text=": " />
                            <Run Text="{Binding ActivePackageDisplay}" />
                        </TextBlock>
                        <TextBlock
                            Margin="0,6,0,0"
                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                            Text="{Binding PackageManagerStatus}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <WrapPanel
                        Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top">
                        <ui:Button
                            Margin="0,0,8,8"
                            Command="{Binding ImportPackageCommand}"
                            Content="{lex:Loc ImportPackage}" />
                        <ui:Button
                            Margin="0,0,8,8"
                            Command="{Binding ExportPackageCommand}"
                            Content="{lex:Loc ExportPackage}" />
                        <ui:Button
                            Margin="0,0,0,8"
                            Command="{Binding RefreshPackagesCommand}"
                            Content="{lex:Loc RefreshPackages}" />
                    </WrapPanel>
                </Grid>

                <Border
                    Grid.Row="1"
                    Padding="10"
                    Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            FontSize="15"
                            FontWeight="SemiBold"
                            Text="{lex:Loc CompactPackageList}" />
                        <ListBox
                            Grid.Row="1"
                            Margin="0,8,0,0"
                            Background="Transparent"
                            BorderThickness="0"
                            ItemsSource="{Binding LayoutPackages}"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            SelectedItem="{Binding SelectedPackage, Mode=TwoWay}">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,6" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border
                                                    x:Name="ItemBorder"
                                                    Padding="10,8"
                                                    Background="Transparent"
                                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="7">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
                                                        <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                                                        <Setter TargetName="ItemBorder" Property="BorderThickness" Value="2" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock
                                                FontSize="14"
                                                FontWeight="SemiBold"
                                                Text="{Binding Name}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Margin="0,3,0,0"
                                                FontSize="12"
                                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                Text="{Binding PackageId}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <WrapPanel
                                            Grid.Column="1"
                                            Margin="12,0,0,0"
                                            HorizontalAlignment="Right">
                                            <Border
                                                Padding="7,2"
                                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                CornerRadius="4">
                                                <TextBlock FontSize="11" Text="{Binding Source}" />
                                            </Border>
                                            <Border
                                                Margin="6,0,0,0"
                                                Padding="7,2"
                                                Background="{DynamicResource SystemFillColorSuccessBrush}"
                                                CornerRadius="4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11" Text="{lex:Loc ActivePackage}" />
                                            </Border>
                                        </WrapPanel>
                                        <WrapPanel
                                            Grid.Row="1"
                                            Grid.ColumnSpan="2"
                                            Margin="0,8,0,0">
                                            <Border
                                                Padding="7,2"
                                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                CornerRadius="4">
                                                <TextBlock FontSize="11" Text="{Binding ValidationStatus}" />
                                            </Border>
                                            <TextBlock
                                                Margin="8,1,0,0"
                                                FontSize="12"
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                Text="{Binding Description}"
                                                TextTrimming="CharacterEllipsis" />
                                        </WrapPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <Border
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    Padding="12"
                    Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid MinHeight="0" ClipToBounds="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="{Binding SelectedPackage.Name}"
                                TextWrapping="Wrap" />
                            <TextBlock
                                Margin="0,4,0,0"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="{Binding SelectedPackage.Description}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <WrapPanel Grid.Row="1" Margin="0,12,0,12">
                            <ui:Button
                                Margin="0,0,8,8"
                                Command="{Binding ActivatePackageCommand}"
                                Content="{lex:Loc ActivatePackage}" />
                            <ui:Button
                                Margin="0,0,8,8"
                                Command="{Binding OpenPackageFolderCommand}"
                                Content="{lex:Loc OpenPackageFolder}" />
                            <ui:Button
                                Margin="0,0,8,8"
                                Command="{Binding DeletePackageCommand}"
                                Content="{lex:Loc DeletePackage}"
                                Icon="{ui:SymbolIcon Symbol=Delete24}">
                                <ui:Button.Style>
                                    <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="ui:Button">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedPackage.IsBuiltin}" Value="True">
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Button.Style>
                            </ui:Button>
                        </WrapPanel>
                        <ui:DynamicScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border
                                    Margin="0,0,0,10"
                                    Padding="10"
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                    CornerRadius="7">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="{lex:Loc PackageBasicInfo}" />
                                        <TextBlock
                                            Margin="0,8,0,0"
                                            Text="{Binding SelectedPackage.PackageId}"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            Margin="0,4,0,0"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            Text="{Binding SelectedPackage.Author}"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            Margin="0,4,0,0"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            Text="{Binding SelectedPackage.MinVersion}"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border
                                    Margin="0,0,0,10"
                                    Padding="10"
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                    CornerRadius="7">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="{lex:Loc PackageContents}" />
                                        <WrapPanel Margin="0,8,0,0">
                                            <TextBlock Text="{lex:Loc LayoutCount}" />
                                            <TextBlock Text=": " />
                                            <TextBlock Margin="0,0,14,0" Text="{Binding SelectedPackage.LayoutCount}" />
                                            <TextBlock Text="{lex:Loc ResourceCount}" />
                                            <TextBlock Text=": " />
                                            <TextBlock Text="{Binding SelectedPackage.ResourceCount}" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                                <Border
                                    Margin="0,0,0,10"
                                    Padding="10"
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                    CornerRadius="7">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="{lex:Loc PackageLocation}" />
                                        <ui:TextBox
                                            Margin="0,8,0,0"
                                            IsReadOnly="True"
                                            Text="{Binding SelectedPackage.InstallPath}"
                                            ToolTip="{Binding SelectedPackage.InstallPath}" />
                                    </StackPanel>
                                </Border>
                                <Border
                                    Padding="10"
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                    CornerRadius="7">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="{lex:Loc PackageValidation}" />
                                        <WrapPanel Margin="0,8,0,0">
                                            <Border
                                                Padding="7,2"
                                                Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                                CornerRadius="4">
                                                <TextBlock FontSize="11" Text="{Binding SelectedPackage.ValidationStatus}" />
                                            </Border>
                                        </WrapPanel>
                                        <TextBlock
                                            Margin="0,8,0,0"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            Text="{Binding SelectedPackage.ValidationMessage}"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ui:DynamicScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </TabItem>
    </TabControl>
</Page>
