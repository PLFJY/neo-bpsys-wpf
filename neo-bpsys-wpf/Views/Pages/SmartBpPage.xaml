<Page
    x:Class="neo_bpsys_wpf.Views.Pages.SmartBpPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cv="clr-namespace:neo_bpsys_wpf.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:neo_bpsys_wpf.ViewModels.Pages"
    Title="SmartBpPage"
    d:DataContext="{d:DesignInstance Type=vm:SmartBpPageViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1000"
    d:DesignWidth="685"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <cv:InverseBooleanConverter x:Key="InverseBooleanConverter" />
    </Page.Resources>

    <StackPanel Margin="10,0,10,0">
        <TextBlock Style="{StaticResource Title}" Text="窗口捕获设置" />
        <Border Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Text="捕获方式" />
                    <ComboBox
                        Width="240"
                        Margin="10,0,0,0"
                        ItemsSource="{Binding CaptureMethodList}"
                        SelectedIndex="{Binding SelectedCaptureMethodIndex}"
                        SelectedValue="{Binding SelectedCaptureMethod}"
                        SelectedValuePath="Method">
                        <ComboBox.ItemContainerStyle>
                            <Style BasedOn="{StaticResource {x:Type ComboBoxItem}}" TargetType="ComboBoxItem">
                                <Setter Property="IsEnabled" Value="{Binding IsAvaliable}" />
                            </Style>
                        </ComboBox.ItemContainerStyle>
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <StackPanel
                    Grid.Row="1"
                    Margin="0,10,0,0"
                    Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Text="选择游戏窗口进程" />
                    <ComboBox
                        MinWidth="220"
                        Margin="10,0,0,0"
                        ItemsSource="{Binding ActiveWindows}"
                        SelectedValue="{Binding SelectedWindow}" />
                    <ui:Button
                        Margin="10,0,0,0"
                        Command="{Binding RefreshActiveWindowsCommand}"
                        Content="刷新"
                        Icon="{ui:SymbolIcon Symbol=ArrowSync24}" />
                    <ui:Button
                        Margin="10,0,0,0"
                        Command="{Binding OpenWindowPickerCommand}"
                        Content="打开窗口选择器（仅WGC可用）" />
                </StackPanel>
                <StackPanel
                    Grid.Row="2"
                    Margin="0,10,0,0"
                    Orientation="Horizontal">
                    <ui:Button
                        Command="{Binding StartCaptureCommand}"
                        Content="开始捕获"
                        Icon="{ui:SymbolIcon Symbol=WindowPlay20}" />
                    <ui:Button
                        Margin="10,0,0,0"
                        Command="{Binding StopCaptureCommand}"
                        Content="停止捕获"
                        Icon="{ui:SymbolIcon Symbol=ShareScreenStop24}" />
                    <ui:Button
                        Margin="10,0,0,0"
                        Command="{Binding OpenPreviewWindowCommand}"
                        Content="打开预览"
                        Icon="{ui:SymbolIcon Symbol=WindowNew24}" />
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock
            Margin="0,10,0,0"
            Style="{StaticResource Title}"
            Text="OCR 模型管理" />
        <Border Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel
                    Grid.Row="0"
                    Margin="0,10,0,0"
                    Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Text="模型选择" />
                    <ComboBox
                        Width="440"
                        Margin="10,0,0,0"
                        ItemsSource="{Binding OcrModelList}"
                        SelectedItem="{Binding SelectedOcrModel}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                        Text="{Binding Description}" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel
                    Grid.Row="1"
                    Margin="0,10,0,0"
                    Orientation="Horizontal">
                    <ui:Button
                        Command="{Binding DownloadSelectedOcrModelCommand}"
                        Content="下载模型"
                        Icon="{ui:SymbolIcon Symbol=ArrowDownload24}"
                        Visibility="{Binding ShowDownloadModelButton, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <ui:Button
                        Command="{Binding DeleteSelectedOcrModelCommand}"
                        Content="删除模型"
                        Icon="{ui:SymbolIcon Symbol=Delete24}"
                        Visibility="{Binding ShowDeleteModelButton, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <ui:Button
                        Margin="10,0,0,0"
                        Command="{Binding SwitchSelectedOcrModelCommand}"
                        Content="切换为当前模型"
                        Icon="{ui:SymbolIcon Symbol=Save24}" />
                    <ui:Button
                        Margin="10,0,0,0"
                        Command="{Binding RefreshOcrModelStatusCommand}"
                        Content="刷新状态"
                        Icon="{ui:SymbolIcon Symbol=ArrowSync24}" />
                    <ui:Button
                        Margin="10,0,0,0"
                        Command="{Binding CancelOcrModelDownloadCommand}"
                        Content="取消下载"
                        Icon="{ui:SymbolIcon Symbol=Stop24}"
                        Visibility="{Binding IsModelDownloading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>

                <StackPanel
                    Grid.Row="2"
                    Margin="0,10,0,0"
                    Visibility="{Binding IsModelDownloading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding ModelDownloadStageText}" />
                    <StackPanel
                        Margin="0,6,0,0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <ui:ProgressRing
                            Width="26"
                            Height="26"
                            IsIndeterminate="True"
                            Visibility="{Binding HasPreciseDownloadProgress, Converter={StaticResource InverseBooleanConverter}}" />
                        <StackPanel
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Visibility="{Binding HasPreciseDownloadProgress, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ProgressBar
                                Width="260"
                                Height="20"
                                Value="{Binding ModelDownloadProgress}" />
                            <TextBlock
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                Text="{Binding ModelDownloadProgressText}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    Grid.Row="3"
                    Margin="0,10,0,0"
                    Orientation="Horizontal">
                    <TextBlock Text="{Binding CurrentOcrModelText}" />
                </StackPanel>
            </Grid>
        </Border>
    </StackPanel>
</Page>
